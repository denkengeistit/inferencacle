# Oracle config (runs on iMac M4 32GB)
# Use Ollama or LM Studio locally
ORACLE_MODEL=qwen2.5:32b
ORACLE_API_BASE=http://localhost:11434/v1    # Ollama (or http://localhost:1234/v1 for LM Studio)
ORACLE_API_KEY=no-key

# Heavy local backend (Mac Mini M4 Pro 48GB via Thunderbolt)
LOCAL_HEAVY_MODEL=qwen2.5:72b
LOCAL_HEAVY_API_BASE=http://mac-mini.local:8000/v1    # Adjust to your Mac Mini's hostname/IP
LOCAL_HEAVY_API_KEY=no-key

# Cloud fallback (disabled by default - set to enable)
# CLOUD_ENABLED=false
# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...

# Routing thresholds
COMPLEXITY_TOKEN_THRESHOLD=800      # estimated tokens above this → heavy/cloud
PII_BLOCK_CLOUD=true                # if PII detected, block cloud routing

# Redaction
REDACTION_ENABLED=true
REDACTION_ENTITIES=PERSON,EMAIL_ADDRESS,PHONE_NUMBER,CREDIT_CARD,US_SSN,US_PASSPORT,IBAN_CODE

# Server
ORACLE_PORT=9000
LOG_LEVEL=INFO
